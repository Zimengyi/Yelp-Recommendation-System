# ──────────────────── Python ────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# ──────────────────── Virtual envs ────────────────────
venv/
env/
.venv/
.env/
ENV/

# ──────────────────── Jupyter ────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/

# ──────────────────── Data (large / reproducible from raw) ────────────────────
# Raw Yelp data — get from official Yelp Open Dataset, not committed
data/raw/*
!data/raw/.gitkeep

# Cleaned + features — reproducible by running scripts/
data/cleaned/*
!data/cleaned/.gitkeep
# tiny JSONs are committed for team visibility; parquet/big artifacts regenerable
data/features/*
!data/features/.gitkeep
!data/features/cuisine_vocab.json
!data/features/feature_spec.json
!data/features/region_clusters.json

# Big intermediates
*.parquet
*.feather
*.arrow
!data/sample/*.parquet  # tiny demo samples can be committed

# ──────────────────── Model artifacts ────────────────────
# Big checkpoints gitignored (regenerable); JSON metrics + history committed
models/*
!models/.gitkeep
!models/*.json
*.pt
*.pth
*.pkl
*.joblib
*.ckpt
*.safetensors

# ──────────────────── Reports / figures / logs ────────────────────
# EDA / training figures committed for reviewer / team visibility
# (re-run scripts/ to regenerate; commit when content meaningfully changes)
!reports/figures/eda_*.png
!reports/figures/training_*.png
!reports/figures/.gitkeep
# Training stdout logs (per phase / per sweep) — small text, huge debug value
!reports/training_logs/
!reports/training_logs/*.log
!reports/training_logs/.gitkeep
# Run records: per-script-invocation markdown narrative (command / args / outputs / findings)
!reports/run_records/
!reports/run_records/*.md
!reports/run_records/.gitkeep

# ──────────────────── OS / IDE ────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ──────────────────── Secrets / config ────────────────────
.env
.env.local
*.key
secrets/
credentials.json
*api_key*
*ANTHROPIC*

# ──────────────────── Misc ────────────────────
*.log
logs/
tmp/
.cache/
