# ──────────────────── Python ────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# ──────────────────── Virtual envs ────────────────────
venv/
env/
.venv/
.env/
ENV/

# ──────────────────── Jupyter ────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/

# ──────────────────── Data (large / reproducible from raw) ────────────────────
# Raw Yelp data — get from official Yelp Open Dataset, not committed
data/raw/*
!data/raw/.gitkeep

# Cleaned + features — reproducible by running scripts/
data/cleaned/*
!data/cleaned/.gitkeep
# tiny JSONs (cuisine_vocab + feature_spec) are committed; rest of features/ is regenerable
data/features/*
!data/features/.gitkeep
!data/features/cuisine_vocab.json
!data/features/feature_spec.json

# Big intermediates
*.parquet
*.feather
*.arrow
!data/sample/*.parquet  # tiny demo samples can be committed

# ──────────────────── Model artifacts ────────────────────
models/*
!models/.gitkeep
*.pt
*.pth
*.pkl
*.joblib
*.ckpt
*.safetensors

# ──────────────────── Reports / figures ────────────────────
# EDA / training figures committed for reviewer / team visibility
# (re-run scripts/ to regenerate; commit when content meaningfully changes)
!reports/figures/eda_*.png
!reports/figures/training_*.png
!reports/figures/.gitkeep

# ──────────────────── OS / IDE ────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ──────────────────── Secrets / config ────────────────────
.env
.env.local
*.key
secrets/
credentials.json
*api_key*
*ANTHROPIC*

# ──────────────────── Misc ────────────────────
*.log
logs/
tmp/
.cache/
